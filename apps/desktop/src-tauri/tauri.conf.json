{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgentPass",
  "version": "1.0.2",
  "identifier": "dev.agentpass.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:15273",
    "beforeDevCommand": "pnpm --filter @agentpass/desktop dev",
    "beforeBuildCommand": "pnpm --filter @agentpass/desktop build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AgentPass",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:*; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/sooua/agentpass/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZGMzk5NjdEQzhFQTg2RkEKUldUNmh1cklmWlk1YnpwenFwSnBUSUhreWEybjMvT1V4OFJuYjl3OFlVdW9TS2xoek9qUkEzRUUK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
