{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "agentpass",
  "version": "0.1.0",
  "identifier": "dev.agentpass.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:15273",
    "beforeDevCommand": "pnpm --filter @agentpass/desktop dev",
    "beforeBuildCommand": "pnpm --filter @agentpass/desktop build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:*; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/OWNER/REPO/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFBODJCNTREMjg5RTMyQkUKUldTK01wNG9UYldDR3BJSEtqNnlCWDRlYlBHMUNvMDdaSlpVeUFYcSt5NkdYQlVBTm9tbnNZcG0K"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
