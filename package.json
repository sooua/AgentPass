{
  "name": "agentpass",
  "version": "1.0.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit || tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "daemon": "pnpm --filter @agentpass/daemon start",
    "daemon:dev": "pnpm --filter @agentpass/daemon dev",
    "mcp": "pnpm --filter @agentpass/mcp-server start",
    "ui:dev": "pnpm --filter @agentpass/desktop dev",
    "tauri:dev": "pnpm --filter @agentpass/desktop tauri dev",
    "clean": "rimraf packages/*/dist apps/*/dist"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
